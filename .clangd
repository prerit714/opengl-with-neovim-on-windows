InlayHints:
  Enabled: true

CompileFlags:
  CompilationDatabase: build/debug
  Add:
    - -Wall
    - -Wextra
    - -Wpedantic
    - -Werror
    - -Wconversion
    - -Wsign-conversion
    - -Wshadow
    - -Wformat=2
    - -Wundef

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - bugprone-*
      - performance-*
      - readability-*
      - modernize-*
